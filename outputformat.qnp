enum OutputFormat:
    bin, bintxt, hextxt, qism

fn<u8 const*> getOutputFormatName(OutputFormat format):
    if format == OutputFormat.bin:
        return "bin"
    elif format == OutputFormat.bintxt:
        return "bintxt"
    elif format == OutputFormat.hextxt:
        return "hextxt"
    elif format == OutputFormat.qism:
        return "qism"

    return "unknown"