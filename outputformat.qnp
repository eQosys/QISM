enum DataFormat:
    bin, bintxt, hextxt, qism

fn<u8 const*> getOutputFormatName(DataFormat format):
    if format == DataFormat.bin:
        return "bin"
    elif format == DataFormat.bintxt:
        return "bintxt"
    elif format == DataFormat.hextxt:
        return "hextxt"
    elif format == DataFormat.qism:
        return "qism"

    return "unknown"